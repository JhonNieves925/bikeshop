{
  "routes": [
    { "src": "/api/(.*)", "dest": "https://bikeshop-rxow.onrender.com/api/$1" },
    { "src": "/uploads/(.*)", "dest": "https://bikeshop-rxow.onrender.com/uploads/$1" },
    { "src": "^/$", "dest": "/tienda/", "status": 302 },
    { "handle": "filesystem" },
    { "src": "/tienda/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/tienda/icons/(.*)", "dest": "/icons/$1" },
    { "src": "/tienda/([^/]+\\.(js|css|png|svg|ico|json|webmanifest|woff2|txt))", "dest": "/$1" },
    { "src": "/tienda/(.*)", "dest": "/" }
  ]
}
