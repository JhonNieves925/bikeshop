# ============================================================
#  Variables de entorno requeridas para producción
#  Copia este archivo a .env y rellena los valores reales.
#  NUNCA subas el .env al repositorio — agrégalo al .gitignore
# ============================================================

# Base de datos (usa un usuario dedicado, NO root)
DB_HOST=tu-servidor-mysql
DB_PORT=3306
DB_NAME=bikeshop
DB_USER=bikeshop_app
DB_PASSWORD=CAMBIA_ESTO_POR_UNA_CLAVE_FUERTE

# JWT — genera con: openssl rand -base64 64
JWT_SECRET=GENERA_UN_SECRETO_ALEATORIO_DE_64_CARACTERES_MINIMO_AQUI

# CORS — tu dominio real
CORS_ORIGINS=https://www.tudominio.com,https://tudominio.com

# Email SMTP
MAIL_USERNAME=tu@email.com
MAIL_PASSWORD=TU_APP_PASSWORD_DE_GMAIL
MAIL_SENDER_NAME=BikeShop

# Twilio (WhatsApp) — opcional
TWILIO_SID=TU_ACCOUNT_SID
TWILIO_TOKEN=TU_AUTH_TOKEN
