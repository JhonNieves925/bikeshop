{
  "routes": [
    { "src": "/api/(.*)", "dest": "https://bikeshop-rxow.onrender.com/api/$1" },
    { "src": "/uploads/(.*)", "dest": "https://bikeshop-rxow.onrender.com/uploads/$1" },
    { "src": "^/$", "dest": "/panel/staff/login", "status": 302 },
    { "handle": "filesystem" },
    { "src": "/panel/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/panel/icons/(.*)", "dest": "/icons/$1" },
    { "src": "/panel/([^/]+\\.(js|css|png|svg|ico|json|webmanifest|woff2|txt))", "dest": "/$1" },
    { "src": "/panel/(.*)", "dest": "/" }
  ]
}
